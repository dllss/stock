@echo off
chcp 65001 >nulREM ==========================================REM 快速更新脚本 - Windows版本REM ==========================================REM REM 功能：仅更新基础数据（实时行情、资金流向等）REM 适用场景：每个交易日收盘后快速更新REM 预计耗时：15-20分钟REMREM 使用方法：REM   1. 双击运行此脚本REM   2. 或在命令行中执行：instock\bin\quick_update.batREMREM ==========================================cd /d %~dp0..echo.echo ==========================================echo    快速更新基础数据echo ==========================================echo.REM 记录开始时间set START_TIME=%time%echo 开始时间: %START_TIME%echo.REM ==========================================REM 运行基础数据更新REM ==========================================echo [1/1] 运行基础数据更新...echo ------------------------------------------python instock/job/execute_daily_job.pyif errorlevel 1 (    echo.    echo ? 基础数据更新失败！    echo 请检查日志文件：instock\log\stock_execute_job.log    pause    exit /b 1)echo ? 基础数据更新完成echo.REM ==========================================REM 完成REM ==========================================set END_TIME=%time%echo ==========================================echo    ? 快速更新完成！echo ==========================================echo.echo 开始时间: %START_TIME%echo 结束时间: %END_TIME%echo.echo 详细日志：instock\log\stock_execute_job.logecho.pause