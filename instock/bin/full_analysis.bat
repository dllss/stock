@echo off
chcp 65001 >nulREM ==========================================REM 完整数据分析脚本 - Windows版本REM ==========================================REM REM 功能：依次运行所有数据分析任务（包含基础数据抓取）REM 适用场景：周末或节假日进行全面分析REM 预计耗时：60-90分钟REMREM 注意：此脚本会先抓取基础数据，再进行分析REM 如果只需要技术分析，请使用 technical_analysis.batREMREM 使用方法：REM   1. 双击运行此脚本REM   2. 或在命令行中执行：instock\bin\full_analysis.batREMREM ==========================================cd /d %~dp0..echo.echo ==========================================echo    开始完整数据分析echo ==========================================echo.echo 注意：此过程可能需要60-90分钟，请耐心等待echo.pauseREM 记录开始时间set START_TIME=%time%echo 开始时间: %START_TIME%echo.REM ==========================================REM 步骤1：基础数据更新REM ==========================================echo [1/4] 运行基础数据更新...echo ------------------------------------------python instock/job/execute_daily_job.pyif errorlevel 1 (    echo.    echo ? 基础数据更新失败！    echo 请检查日志文件：instock\log\stock_execute_job.log    pause    exit /b 1)echo ? 基础数据更新完成echo.REM ==========================================REM 步骤2：技术指标计算REM ==========================================echo [2/4] 计算技术指标...echo ------------------------------------------python instock/job/indicators_data_daily_job.pyif errorlevel 1 (    echo.    echo ?? 技术指标计算失败（可继续）    echo 请检查日志文件：instock\log\stock_execute_job.log    echo.    choice /C YN /M "是否继续执行后续任务"    if errorlevel 2 exit /b 1)echo ? 技术指标计算完成echo.REM ==========================================REM 步骤3：K线形态识别REM ==========================================echo [3/4] 识别K线形态...echo ------------------------------------------python instock/job/klinepattern_data_daily_job.pyif errorlevel 1 (    echo.    echo ?? K线形态识别失败（可继续）    echo 请检查日志文件：instock\log\stock_execute_job.log    echo.    choice /C YN /M "是否继续执行后续任务"    if errorlevel 2 exit /b 1)echo ? K线形态识别完成echo.REM ==========================================REM 步骤4：策略选股REM ==========================================echo [4/4] 策略选股...echo ------------------------------------------python instock/job/strategy_data_daily_job.pyif errorlevel 1 (    echo.    echo ?? 策略选股失败    echo 请检查日志文件：instock\log\stock_execute_job.log    pause    exit /b 1)echo ? 策略选股完成echo.REM ==========================================REM 完成REM ==========================================set END_TIME=%time%echo ==========================================echo    ? 完整数据分析完成！echo ==========================================echo.echo 开始时间: %START_TIME%echo 结束时间: %END_TIME%echo.echo 详细日志：instock\log\stock_execute_job.logecho.pause